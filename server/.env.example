# ==================== 微信小程序配置 ====================
# 小程序 AppID（在 mp.weixin.qq.com 注册后获取）
WECHAT_APPID=your_appid_here
# 小程序 AppSecret
WECHAT_APPSECRET=your_appsecret_here

# ==================== JWT 配置 ====================
# JWT 密钥（生产环境务必修改）
JWT_SECRET=esports-platform-secret-key-change-in-production

# ==================== 服务配置 ====================
# 后端服务端口
PORT=3001
# 数据库类型（默认 sqlite）
DB_TYPE=sqlite
